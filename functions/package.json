{
  "name": "top-seo-specialists-functions",
  "description": "Cloud Functions for Top SEO Specialists",
  "main": "index.js",
  "dependencies": {
    "@google/generative-ai": "^0.15.0",
    "cors": "^2.8.5",
    "firebase-admin": "^12.1.1",
    "firebase-functions": "^5.0.1"
  },
  "devDependencies": {
    "eslint": "^8.13.0",
    "eslint-config-google": "^0.14.0"
  },
  "scripts": {
    "enrich:profiles": "node scripts/enrich-profiles.js",
